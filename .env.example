# Supabase — preencher com valores do projeto remoto (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Connection string do Postgres do Supabase (Settings > Database > Connection string > URI)
# Usada pelos testes RLS estruturais (precisam acesso a pg_class)
SUPABASE_DB_URL=

# Resend — gerar API key em https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=relatorios@fabianobratti.com

# URL absoluta usada em emails transactionais (link pro portal admin)
# Em produção: https://fabianobratti.com
SITE_URL=http://localhost:3000

# Email que recebe notificação quando mecânico submete relatório.
# Se vazio, manda pros emails dos profiles com role=admin no auth.users.
ADMIN_NOTIFICATION_EMAIL=
