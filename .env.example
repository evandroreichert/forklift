# Supabase — preencher com valores do projeto remoto (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Connection string do Postgres do Supabase (Settings > Database > Connection string > URI)
# Usada pelos testes RLS estruturais (precisam acesso a pg_class)
SUPABASE_DB_URL=

# Resend — gerar API key em https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=relatorios@fabianobratti.com

# URL absoluta usada em emails transactionais (link pro portal admin)
# Em produção: https://fabianobratti.com
SITE_URL=http://localhost:3000

# Email que recebe notificação quando mecânico submete relatório
# E quando alguém envia mensagem pelo form de contato do site.
# Se vazio, manda pros emails dos profiles com role=admin no auth.users.
ADMIN_NOTIFICATION_EMAIL=

# Vídeo do hero. Em prod hospede externamente (Vercel Blob/R2/etc) e cole a URL
# aqui pra não bloar o deploy. Se vazio, usa public/videos/hero.mp4.
NEXT_PUBLIC_HERO_VIDEO_URL=

# Habilita /portal/admin/test-email mesmo em produção (debug do Resend).
# Padrão vazio = só funciona em dev.
ALLOW_TEST_EMAIL_PAGE=

# Permite wipeAll() em tests/helpers/supabase.ts apagar usuários no Supabase
# de produção. NUNCA setar 1 em prod. Padrão vazio = bloqueado.
ALLOW_DESTRUCTIVE_WIPE=
